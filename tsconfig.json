{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@domain/*": [
        "./src/domain/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@infrastructure/*": [
        "./src/infrastructure/*"
      ],
      "@ui/*": [
        "./src/ui/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@seo": [
        "./src/seo/index.ts"
      ],
      "@seo/*": [
        "./src/seo/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/tests/**",
    "e2e/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.benchmark.test.ts"
  ]
}
