{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true
    }
  },
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/WoodBine.db*",
      "**/playwright-report/**",
      "**/e2e/**",
      "**/scripts/**",
      "**/tests/**",
      "**/*.md",
      "**/*.csv",
      "**/lint_output.txt",
      "**/test_output.txt",
      "LICENSE",
      "README.md",
      "vitest.config.ts",
      "playwright.config.ts",
      "eslint.config.js",
      "**/*.map"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "2GiB",
      "cpu": 2
    },
    "headers": [
      {
        "source": "**/*.@(js|css|jpg|jpeg|gif|png|svg|webp|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
